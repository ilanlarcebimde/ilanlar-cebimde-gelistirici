# n8n — sitenin sağ alt köşesindeki chat widget (isteğe bağlı). Yerelde “Failed to fetch” istemiyorsanız: NEXT_PUBLIC_N8N_CHAT_ENABLED=false
# NEXT_PUBLIC_N8N_CHAT_WEBHOOK_URL=https://....../webhook/.../chat
# NEXT_PUBLIC_N8N_CHAT_STREAMING=true
# n8n — Nasıl Başvururum? (howto-step) production webhook. Local ve production'da zorunlu.
N8N_HOWTO_WEBHOOK_URL=https://s02c0alq.rcld.app/webhook/1de6a1cf-a74c-4373-98f7-85acde812deb
# n8n — Cover letter (başvuru mektubu) sihirbazı step 6 webhook. Premium Plus; production'da zorunlu.
N8N_LETTER_WEBHOOK_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: /api/cv/save (cv_sessions upsert) – asla client’a vermeyin
SUPABASE_SERVICE_ROLE_KEY=

# PayTR (ödeme) – Key ve Salt sadece sunucuda kullanılır, asla client’a vermeyin
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
# Ödeme callback + Google OAuth redirectTo kökü (Vercel production: https://www.ilanlarcebimde.com — Supabase Site URL ve Redirect URLs ile aynı kök)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Geliştirme ortamında test modu için (isteğe bağlı)
# PAYTR_TEST_MODE=1
# Ödemeleri geçici kapatmak için: NEXT_PUBLIC_PAYMENTS_PAUSED=true
# ADMINSUPER2026 test kuponu — ilanlarcebimde@gmail.com, bugrakesr@gmail.com kodda gömülüdür; ek hesaplar için virgülle liste (opsiyonel)
# Aynı hizmette 1 saatte bir kullanım (yalnızca ADMINSUPER2026_ALLOWED_EMAILS ile eklenen hesaplar); gömülü test e-postalarında yok
# supabase/migrations/059_adminsuper_test_usage.sql bu sınır için gerekli
# ADMINSUPER2026_ALLOWED_EMAILS=yonetici@ornek.com


# ElevenLabs (sesli asistan TTS – sadece sunucu; header: xi-api-key)
ELEVENLABS_API_KEY=
# İsteğe bağlı: voice_id (varsayılan: Rachel), model_id (varsayılan: eleven_turbo_v2_5)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Google Gemini (sesli asistan orkestratörü + CV)
